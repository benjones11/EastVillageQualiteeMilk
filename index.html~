<script>
function showPanel(evt, id) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  const panel = document.getElementById('panel-' + id);
  panel.classList.add('active');

  // Position the panel near the hotspot that was clicked.
  // getBoundingClientRect() returns viewport coords, which matches
  // the panel's `position: fixed` coordinate space.
  const hotspot = evt.currentTarget;
  const rect = hotspot.getBoundingClientRect();
  const gap = 16;
  const margin = 10;
  const panelWidth = panel.offsetWidth;
  const panelHeight = panel.offsetHeight;

  // Prefer placing the panel to the right of the hotspot;
  // flip to the left if it would overflow the viewport.
  let left = rect.right + gap;
  if (left + panelWidth > window.innerWidth - margin) {
    left = rect.left - panelWidth - gap;
  }
  if (left < margin) left = margin;

  // Vertically center the panel on the hotspot, then clamp.
  let top = rect.top + rect.height / 2 - panelHeight / 2;
  const maxTop = window.innerHeight - panelHeight - margin;
  if (top < margin) top = margin;
  if (top > maxTop) top = maxTop;

  panel.style.left = left + 'px';
  panel.style.top  = top  + 'px';
}
function closePanel() {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
}
</script>
